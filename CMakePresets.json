{
  "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "$comment": "A CMakePresets.json file for STRATA project",
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Config",
      "description": "Default build using Ninja generator",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/cmake-build/default",
      "cacheVariables": {
        "BUILD_FOR_BELA": {
          "value": "FALSE",
          "type": "BOOL"
        }
      }
    },
    {
      "name": "osx-only",
      "inherits": "default",
      "displayName": "OS X-only configuration",
      "description": "This build is only available on OS X",
      "binaryDir": "${sourceDir}/cmake-build/darwin",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "bela-cross",
      "inherits": "default",
      "displayName": "Bela Config",
      "description": "Bela build using Ninja generator",
      "binaryDir": "${sourceDir}/cmake-build/bela-cross",
      "toolchainFile": "cmake/bela-gcc.toolchain.cmake",
      "cacheVariables": {
        "BUILD_FOR_BELA": {
          "value": "ON",
          "type": "BOOL"
        }
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "bela",
      "configurePreset": "bela-cross"
    },
    {
      "name": "osx",
      "configurePreset": "osx-only"
    }
  ]
}